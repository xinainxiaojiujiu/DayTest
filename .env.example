# ============================================
# 汽车涂装不良品智能分析系统 - 环境配置文件
# ============================================
# 使用说明：
#   1. 复制本文件为 .env ：  copy .env.example .env
#   2. 修改 .env 中的配置项（至少填写一个 LLM 平台的 API Key）
#   3. 运行 start.bat 启动系统
# ============================================

# ============ 应用基础配置 ============
APP_NAME=AutomotiveCoatingDefectAnalysis
DEBUG=false

# ============ LLM 平台选择 ============
# 可选值: dashscope（阿里云百炼） 或 dify（Dify公司级部署平台）
LLM_PLATFORM=dashscope

# ============ 阿里云百炼 API 配置 ============
# 从阿里云控制台获取: https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=your_dashscope_api_key
# 模型选择: qwen-max（最强）/ qwen-plus（均衡）/ qwen-turbo（快速）
DASHSCOPE_MODEL=qwen-max

# ============ Dify 平台 API 配置 ============
# Dify 公司级部署平台地址
DIFY_API_URL=https://aicenter.dongfeng-nissan.com.cn/v1
# 从 Dify 控制台获取 API Key
DIFY_API_KEY=your_dify_api_key
# 响应模式: streaming（流式返回）/ blocking（阻塞返回）
DIFY_RESPONSE_MODE=streaming

# ============ LLM 通用参数 ============
LLM_MAX_RETRIES=3
LLM_RETRY_DELAY=2.0
LLM_TIMEOUT=60.0
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.1

# ============ MySQL 数据库配置 ============
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=coating_defect

# ============ InfluxDB 时序数据库配置 ============
INFLUX_URL=http://127.0.0.1:8086
INFLUX_TOKEN=your_influx_token
INFLUX_ORG=coating
INFLUX_BUCKET=sensor_data

# ============ ChromaDB 向量数据库配置 ============
CHROMA_HOST=127.0.0.1
CHROMA_PORT=8000
CHROMA_COLLECTION=process_knowledge

# ============ Redis / Celery 配置 ============
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1

# ============ MES 系统对接配置 ============
MES_API_BASE_URL=http://mes.internal/api/v1
MES_API_KEY=your_mes_api_key

# ============ 安川机器人对接配置 ============
ROBOT_HOST=192.168.1.100
ROBOT_PORT=10000

# ============ 环境传感器配置 (Modbus TCP) ============
SENSOR_HOST=192.168.1.200
SENSOR_PORT=502

# ============ OCR 配置 ============
OCR_USE_GPU=false
OCR_LANG=ch
